# Database
POSTGRES_USER=qisur
POSTGRES_PASSWORD=qisur
POSTGRES_DB=qisur_db
# For app inside Docker use: postgres://user:pass@postgres:5432/dbname
# For local clients like DBeaver use: postgres://user:pass@localhost:5433/dbname
DATABASE_URL=postgres://qisur:qisur@localhost:5433/qisur_db

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=24

# Server
PORT=8080

# Seeders (true to populate with test data)
SEED=true

# WebSocket Configuration
# Max message size in bytes (default: 524288 = 512KB)
# Increase for large payloads, decrease to limit memory usage
WS_MAX_MESSAGE_SIZE=524288

# Client send buffer size (default: 512)
# Number of messages queued per client before dropping slow clients
# Higher = more memory per client, lower = disconnect slow clients faster
WS_CLIENT_SEND_BUFFER=512

# Hub broadcast channel buffer (default: 1024)
# Number of messages buffered in broadcast channel
# Higher = less contention, lower = faster memory cleanup
WS_HUB_BROADCAST_BUFFER=1024

# Write timeout in seconds (default: 10)
# Time to write message before connection is closed
WS_WRITE_WAIT_SECONDS=10

# Pong timeout in seconds (default: 60)
# Time to receive pong before connection is closed
WS_PONG_WAIT_SECONDS=60
